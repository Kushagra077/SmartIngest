# ---------------------------------------------------------------------------
# SmartIngest environment configuration
# Copy this file to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# --- Gemini API (multimodal classification + extraction) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Model used for vision + structured extraction.
GEMINI_MODEL=gemini-2.0-flash

# --- LangSmith tracing (optional but recommended) ---
# When enabled, every graph node is traced as a run in LangSmith.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=smartingest

# --- Application settings ---
# SQLite path for the job state store.
SMARTINGEST_DB_PATH=data/jobs.db
# Directory where uploaded documents are persisted.
SMARTINGEST_UPLOAD_DIR=data/uploads
# Path to the business-rules configuration consumed by the Validator.
SMARTINGEST_RULES_PATH=config/rules.yaml

# Run the pipeline without calling Gemini (deterministic stub responses).
# Useful for local development, demos, and CI where no API key is available.
SMARTINGEST_MOCK_LLM=true

# Extraction-confidence floor; below this the Validator triggers a retry.
SMARTINGEST_MIN_CONFIDENCE=0.75
# Maximum number of Extractor retries before giving up.
SMARTINGEST_MAX_RETRIES=2

# --- Guardrails (security) ---
# Run the input-scan / grounding guardrails (injection + PII + grounding).
SMARTINGEST_ENABLE_GUARDRAILS=true
# Reject uploads larger than this many megabytes.
SMARTINGEST_MAX_FILE_SIZE_MB=25

# FastAPI backend base URL used by the Streamlit frontend.
SMARTINGEST_API_URL=http://localhost:8000
